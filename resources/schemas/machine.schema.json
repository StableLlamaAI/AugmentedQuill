{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/machine.schema.json",
  "title": "Machine Configuration Schema",
  "description": "Schema for validating machine.json configuration file",
  "type": "object",
  "properties": {
    "openai": {
      "type": "object",
      "properties": {
        "models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "base_url": {
                "type": "string",
                "format": "uri"
              },
              "api_key": {
                "type": "string"
              },
              "timeout_s": {
                "type": "integer",
                "minimum": 1
              },
              "model": {
                "type": "string"
              },
              "temperature": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 2
              },
              "top_p": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 1
              },
              "max_tokens": {
                "type": ["integer", "null"],
                "minimum": 1
              },
              "presence_penalty": {
                "type": ["number", "null"],
                "minimum": -2,
                "maximum": 2
              },
              "frequency_penalty": {
                "type": ["number", "null"],
                "minimum": -2,
                "maximum": 2
              },
              "stop": {
                "type": ["array", "null"],
                "items": {
                  "type": "string"
                }
              },
              "seed": {
                "type": ["integer", "null"]
              },
              "top_k": {
                "type": ["integer", "null"],
                "minimum": 1
              },
              "min_p": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 1
              },
              "extra_body": {
                "type": ["string", "null"]
              },
              "preset_id": {
                "type": ["string", "null"]
              },
              "writing_warning": {
                "type": ["string", "null"]
              },
              "is_multimodal": {
                "type": ["boolean", "null"]
              },
              "supports_function_calling": {
                "type": ["boolean", "null"]
              },
              "prompt_overrides": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": ["name", "base_url", "api_key", "timeout_s", "model"]
          }
        },
        "selected": {
          "type": "string",
          "description": "The selected model name"
        },
        "selected_chat": {
          "type": "string"
        },
        "selected_writing": {
          "type": "string"
        },
        "selected_editing": {
          "type": "string"
        }
      },
      "required": ["models", "selected"]
    }
  },
  "required": ["openai"]
}
