{
  "name": "augmentedquill",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "check:exports": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check:dead-exports": "ts-prune -p tsconfig.json",
    "check:bundle-budget": "node scripts/checkBundleBudget.mjs",
    "build": "npm run typecheck && vite build && npm run check:bundle-budget",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:accessibility": "vitest run features/layout/ConfirmDialog.test.tsx features/chat/ToolCallLimitDialog.test.tsx features/story/MetadataEditorDialog.test.tsx features/settings/settings/SettingsMachine.test.tsx"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@google/genai": "^1.48.0",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@testing-library/dom": "^10.4.1",
    "@types/diff-match-patch": "^1.0.36",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "codemirror": "^6.0.2",
    "diff-match-patch": "^1.0.5",
    "dompurify": "^3.4.0",
    "i18next": "^26.0.4",
    "lucide-react": "^1.8.0",
    "marked": "17.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "turndown": "7.2.4",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.2.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "ts-prune": "^0.10.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
